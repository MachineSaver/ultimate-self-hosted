  # ── Embedded Outpost — assign all proxy providers ────────────────
  # This configures the built-in authentik outpost that Traefik's
  # forwardAuth middleware points to.
  - model: authentik_outposts.outpost
    state: present
    identifiers:
      name: authentik Embedded Outpost
    attrs:
      name: authentik Embedded Outpost
      type: proxy
      providers:
        - !Find [authentik_providers_proxy.proxyprovider, [name, jellyfin]]
        - !Find [authentik_providers_proxy.proxyprovider, [name, jellyseerr]]
        - !Find [authentik_providers_proxy.proxyprovider, [name, booklore]]
        - !Find [authentik_providers_proxy.proxyprovider, [name, navidrome]]
        - !Find [authentik_providers_proxy.proxyprovider, [name, sonarr]]
        - !Find [authentik_providers_proxy.proxyprovider, [name, radarr]]
        - !Find [authentik_providers_proxy.proxyprovider, [name, lidarr]]
        - !Find [authentik_providers_proxy.proxyprovider, [name, prowlarr]]
        - !Find [authentik_providers_proxy.proxyprovider, [name, qbittorrent]]
        - !Find [authentik_providers_proxy.proxyprovider, [name, uptime-kuma]]
        - !Find [authentik_providers_proxy.proxyprovider, [name, wireguard]]
        - !Find [authentik_providers_proxy.proxyprovider, [name, headscale-ui]]
        - !Find [authentik_providers_proxy.proxyprovider, [name, traefik]]
      config:
        authentik_host: "https://auth.{{DOMAIN}}"
        authentik_host_insecure: false
        log_level: info
        object_naming_template: "%(name)s"
        docker_labels: null
        docker_network: proxy
        docker_map_ports: true
