# Authentik Blueprint: Proxy (Forward Auth) Providers
# Generated by install.sh
#
# These services don't support native OIDC.
# Traefik forwardAuth middleware calls authentik-server for each request.
# Authentik checks the session cookie and returns 200 (allow) or 302 (redirect to login).

version: 1
metadata:
  name: 02-proxy-providers
  labels:
    blueprints.goauthentik.io/description: Forward auth proxy providers

entries:

  # ── Jellyfin ────────────────────────────────────────────────────
  - model: authentik_providers_proxy.proxyprovider
    state: present
    identifiers:
      name: jellyfin
    attrs:
      name: jellyfin
      mode: forward_single
      external_host: "https://jellyfin.{{DOMAIN}}"
      access_token_validity: "days=1"
      authorization_flow: !Find [authentik_flows.flow, [slug, default-provider-authorization-implicit-consent]]

  - model: authentik_core.application
    state: present
    identifiers:
      slug: jellyfin
    attrs:
      name: Jellyfin
      slug: jellyfin
      provider: !Find [authentik_providers_proxy.proxyprovider, [name, jellyfin]]
      meta_launch_url: "https://jellyfin.{{DOMAIN}}"
      meta_description: Media server
      policy_engine_mode: any

